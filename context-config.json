{
  "schema_version": "1.0.0",
  "generator_version": "1.0.0",
  "source_repos": [
    { "name": "xlotyl",     "path": "../xlotyl",     "repo": "HHPE-HRG/xlotyl",     "primary": true,  "default_branch": "main" },
    { "name": "stoneforge", "path": "../stoneforge", "repo": "HHPE-HRG/stoneforge", "primary": true,  "default_branch": "master" },
    { "name": "claw-code",  "path": "../claw-code",  "repo": "HHPE-HRG/claw-code",  "primary": false, "default_branch": "main" },
    { "name": "void",       "path": "../void",       "repo": "HHPE-HRG/void",       "primary": false, "default_branch": "main" },
    { "name": "openclaw",   "path": "../openclaw",   "repo": "HHPE-HRG/openclaw",   "primary": false, "default_branch": "deployed" }
  ],
  "exclude_patterns": [
    ".git/**",
    "node_modules/**",
    ".venv/**",
    "venv/**",
    "dist/**",
    "build/**",
    "out/**",
    "coverage/**",
    ".cache/**",
    ".turbo/**",
    "__pycache__/**",
    "**/.DS_Store",
    ".env*",
    "**/.env*",
    "secrets*",
    "**/secrets*",
    "**/*.png",
    "**/*.jpg",
    "**/*.jpeg",
    "**/*.webp",
    "**/*.gif",
    "**/*.mp4",
    "**/*.mov",
    "**/*.zip",
    "**/*.tar",
    "**/*.gz",
    "**/*.7z",
    "**/*.pem",
    "**/*.key",
    "**/*.p12",
    "**/*.pfx",
    "**/*.bin",
    "**/*.safetensors",
    "**/*.ckpt",
    "**/*.gguf",
    "**/*.onnx",
    "**/*.parquet",
    "**/*.sqlite",
    "**/*.db"
  ],
  "chunk_size_limit_bytes": 250000,
  "per_file_size_limit_bytes": 200000,
  "xlotyl_chunks": {
    "core-dev-services":     ["services/core-dev-services/src", "services/core-dev-services/PLATFORM_PATHWAYS.md", "services/core-dev-services/SHELL_HOOK_RESPONSIBILITIES.md", "services/core-dev-services/package.json"],
    "capability-packages":   ["capability-packages"],
    "response-control":      ["services/response-control-framework/src", "services/response-control-framework/schemas", "services/response-control-framework/pyproject.toml"],
    "schemas":               ["schemas"],
    "agent-platform":        ["services/agent-platform-service"],
    "model-runtime":         ["services/model-runtime", "schemas/model-runtime"],
    "wiki-response-control": ["knowledge/wiki", "knowledge/response-control"]
  },
  "stoneforge_chunks": {
    "smithy":             ["packages/smithy/src", "packages/smithy/package.json", "packages/smithy/README.md"],
    "quarry":             ["packages/quarry/src", "packages/quarry/package.json", "packages/quarry/README.md"],
    "dashboard":          ["apps/smithy-server/src", "apps/smithy-web/src", "apps/quarry-server/src", "apps/quarry-web/src"],
    "cli":                ["packages/smithy/src/bin", "packages/smithy/src/cli", "packages/quarry/src/bin", "packages/quarry/src/cli"],
    "xlotyl-integration": ["docs/contracts", "docs/wiki"]
  }
}
